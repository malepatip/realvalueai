# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Redis
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Secret used to verify inbound webhooks from Telegram.
# Must be different from the bot token: only [A-Za-z0-9_-] allowed.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# SimpleFIN
SIMPLEFIN_ACCESS_URL=https://your-simplefin-access-url

# NVIDIA NIM API
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Encryption
ENCRYPTION_KEY=your-256-bit-encryption-key-hex
